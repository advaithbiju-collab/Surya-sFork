{
  "version": 2,
  "buildCommand": "npm run build",
  "devCommand": "npm run dev",
  "env": {
    "NODE_ENV": "production"
  },
  "projects": {
    "client": {
      "name": "socio-client",
      "buildCommand": "npm run build --prefix client",
      "outputDirectory": "client/.next",
      "rootDirectory": "client"
    },
    "server": {
      "name": "socio-server",
      "buildCommand": "npm install --prefix server",
      "outputDirectory": "server",
      "rootDirectory": "server"
    }
  },
  "builds": [
    {
      "src": "client/package.json",
      "use": "@vercel/next"
    },
    {
      "src": "server/index.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "server/index.js"
    },
    {
      "src": "/(.*)",
      "dest": "client"
    }
  ]
}
